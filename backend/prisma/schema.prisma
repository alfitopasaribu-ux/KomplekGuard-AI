generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  WARGA
  ADMIN
  SATPAM
  KETUA_RT
}

enum AlertStatus {
  AKTIF
  DIPROSES
  SELESAI
  DIBATALKAN
}

enum RiskLevel {
  RENDAH
  SEDANG
  TINGGI
  KRITIS
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  passwordHash   String
  phone          String?
  role           Role     @default(WARGA)
  address        String?
  latitude       Float?
  longitude      Float?
  neighborhoodId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  neighborhood  Neighborhood?   @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  alerts        Alert[]
  responses     AlertResponse[]
  alertUpdates  AlertUpdate[]
  notifications Notification[]
  activityLogs  ActivityLog[]

  @@index([role])
  @@index([neighborhoodId])
}

model Neighborhood {
  id        String   @id @default(uuid())
  name      String
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users  User[]
  alerts Alert[]
}

model AlertCategory {
  id            String   @id @default(uuid())
  name          String
  type          String
  icon          String?
  color         String?
  priorityLevel Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  alerts Alert[]

  @@unique([name, type])
}

model Alert {
  id                  String       @id @default(uuid())
  userId              String
  categoryId          String?
  neighborhoodId      String?
  customCategory      String?
  title               String
  description         String
  aiSummary           String?
  aiSuggestedCategory String?
  riskLevel           RiskLevel?
  status              AlertStatus  @default(AKTIF)
  latitude            Float
  longitude           Float
  address             String?
  photoUrl            String?
  isPublic            Boolean      @default(true)
  isFalseAlarm        Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  resolvedAt          DateTime?

  user         User                @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  category     AlertCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  neighborhood Neighborhood?       @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  responses    AlertResponse[]
  updates      AlertUpdate[]
  aiSummaries  AIIncidentSummary[]
  notifications Notification[]

  @@index([status])
  @@index([riskLevel])
  @@index([userId])
  @@index([categoryId])
  @@index([neighborhoodId])
  @@index([createdAt])
  @@index([latitude, longitude])
}

model AlertResponse {
  id             String   @id @default(uuid())
  alertId        String
  userId         String
  responseStatus String
  note           String?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([alertId])
  @@index([userId])
}

model AlertUpdate {
  id        String      @id @default(uuid())
  alertId   String
  userId    String
  oldStatus AlertStatus
  newStatus AlertStatus
  note      String?
  createdAt DateTime    @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([alertId])
  @@index([userId])
}

model EmergencyContact {
  id          String   @id @default(uuid())
  name        String
  phone       String
  type        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIIncidentSummary {
  id                String    @id @default(uuid())
  alertId           String
  summary           String
  recommendedAction String
  riskLevel         RiskLevel
  rawAiResponse     String
  createdAt         DateTime  @default(now())

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([alertId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  alertId   String?
  title     String
  message   String
  type      String?  @default("ALERT")
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  alert Alert? @relation(fields: [alertId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId])
  @@index([alertId])
  @@index([isRead])
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  description String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@index([createdAt])
}